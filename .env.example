# StreetSentinel — bootstrap secrets ONLY.
# Generated automatically by install.sh; the operator never edits this file.
# All other settings (public URL, AI keys, Telegram, email, Mapbox, Cloudflare
# token) are configured in the web setup wizard and stored in the database.
#
# Generate a fresh value for each *_KEY / *_SECRET / *_PASSWORD with:
#   openssl rand -hex 32      (32-byte hex)
#   openssl rand -base64 36   (URL-safe-ish base64)

# --- Core security (required) ---
SECRET_KEY=replace-with-openssl-rand-hex-32
CREDENTIAL_ENCRYPTION_KEY=replace-with-openssl-rand-hex-32
WEBHOOK_SECRET=replace-with-openssl-rand-hex-32

# --- Database (bundled Postgres service) ---
POSTGRES_PASSWORD=replace-with-openssl-rand-base64
DATABASE_URL=postgresql+asyncpg://cctv:replace-with-openssl-rand-base64@postgres:5432/cctv_platform

# --- Instance role (single-worker active node) ---
INSTANCE_ROLE=active

# --- Web port ---
PORT=8000

# --- Cloudflare tunnel token path (shared 'config' volume; wizard writes here) ---
TUNNEL_TOKEN_PATH=/config/tunnel/token

# --- YOLO / object detection ---
# Server image ships WITHOUT the local YOLO/torch stack — object detection runs on the edge AI worker. Leave false unless you install the ML deps.
YOLO_ENABLED=false

# --- FTP server (Hikvision uploads) ---
FTP_ENABLED=true
FTP_PORT=2121
FTP_PASSWORD=replace-with-openssl-rand-base64
FTP_PASSIVE_PORT_START=60000
FTP_PASSIVE_PORT_END=60100
